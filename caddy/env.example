# Route53 + TLS credentials for Caddy (copy to .env beside docker-compose.yml).

ACME_EMAIL=you@example.com

# Route 53 (DNS-01). On EC2 you can rely on an instance profile and leave keys blank if the module supports it.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_HOSTED_ZONE_ID=Z0123456789ABCDEFGH
